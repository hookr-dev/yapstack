{
  "name": "yapstack",
  "private": true,
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hookr-dev/YapStack.git"
  },
  "scripts": {
    "dev": "pnpm --filter @yapstack/desktop build:sidecars:dev && pnpm --filter @yapstack/desktop dev:tauri",
    "dev:frontend": "pnpm --filter @yapstack/desktop dev",
    "build": "pnpm --filter @yapstack/desktop build:all",
    "build:sidecar": "pnpm --filter @yapstack/desktop build:sidecar",
    "build:sidecars": "pnpm --filter @yapstack/desktop build:sidecars",
    "build:dmg": "pnpm --filter @yapstack/desktop build:dmg",
    "build:tauri": "pnpm --filter @yapstack/desktop build:tauri",
    "test": "cargo test --all && pnpm --filter @yapstack/desktop test",
    "test:frontend": "pnpm --filter @yapstack/desktop test",
    "test:rust": "cargo test --all",
    "test:watch": "pnpm --filter @yapstack/desktop test:watch",
    "lint": "cargo fmt --all -- --check && cargo clippy --all -- -D warnings && pnpm --filter @yapstack/desktop lint",
    "typecheck": "pnpm --filter @yapstack/desktop typecheck",
    "check": "cargo build --all && cargo test --all && cargo fmt --all -- --check && cargo clippy --all -- -D warnings && pnpm --filter @yapstack/desktop check"
  }
}
