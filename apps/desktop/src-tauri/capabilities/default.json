{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capability for YapStack",
  "windows": ["main", "dictation", "recording-indicator"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "shell:allow-open",
    "sql:default",
    "sql:allow-execute",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "core:window:allow-set-position",
    "core:window:allow-current-monitor",
    "aptabase:allow-track-event",
    "updater:default",
    "process:allow-restart"
  ]
}
